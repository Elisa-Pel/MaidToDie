  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f5334d405a9515042a12be3bed770915, type: 3}
  m_Name: EvieDay2Dial
  m_EditorClassIdentifier: 
  lines:
  - npcName: Everette
    text: AH-?!!!!?
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: "Oh mio dio... Cos'\xE8 quella cosa...?"
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: "Mi avr\xE0 visto?!"
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: ...
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: Ok... ok... OK!
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: Ho un lavoro da fare!
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: Qualunque cosa sia quel mostro...
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: "Aspetter\xF2 che si allontani e lo aggirer\xF2."
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  - npcName: Everette
    text: Non posso permettermi di essere licenziata per non aver pulito come dovevo!
    portrait: {fileID: -6762264116412386452, guid: 7a79f8d52aedf5d4f84f669033c04dd9, type: 3}
  typingSpeed: 0.05
